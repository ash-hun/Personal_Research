# 필수
ANTHROPIC_API_KEY=sk-ant-...

# ── Section 4 캡처 활성화 ──────────────────────────────────────────────────
# 1. 별도 터미널에서 프록시 시작
#    bash script/start_proxy.sh
#
# 2. 아래 주석 해제 후 Claude Code 재시작
# ANTHROPIC_BASE_URL=http://localhost:8082
#
# 3. Claude Code가 툴을 사용하면 dataset/captured_requests.jsonl에 자동 기록
# 4. 캡처 후 노트북 Section 4 실행하여 실제 schema 분석
#
# 프록시 종료: bash script/stop_proxy.sh
LOG_LEVEL=INFO
